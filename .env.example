# SUMUP_API_KEY — Personal access token from developer.sumup.com
SUMUP_API_KEY=sup_sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# SUMUP_AFFILIATE_KEY — From the Affiliate Keys page in the SumUp developer portal
SUMUP_AFFILIATE_KEY=sup_afk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# SUMUP_MERCHANT_CODE — Your sandbox merchant code (e.g. MD4V73S0)
SUMUP_MERCHANT_CODE=XXXXXXXX

# SUMUP_APP_ID — Application identifier from the Affiliate Keys page (reverse-domain format)
SUMUP_APP_ID=com.yourcompany.yourapp

# WEBHOOK_PORT — Local HTTP port the embedded webhook listener binds to (nginx proxies to this)
WEBHOOK_PORT=58180

# WEBHOOK_URL — Public HTTPS URL SumUp will POST transaction results to
# nginx must proxy this to http://127.0.0.1:$WEBHOOK_PORT/webhook
WEBHOOK_URL=https://your-domain.example.com/webhook
